.DS_Store
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.vscode/
.idea/

# Dataset and TensorFlow caches
data/raw/
data/processed/
data/sample/*
!data/sample/README.md
!data/sample/*/
!data/sample/**/*.png
tensorflow_datasets/

# Large model artifacts stay ignored, but compact training metadata is tracked
# for the presentation dashboard.
artifacts/*
!artifacts/README.md
!artifacts/*/
!artifacts/*/config.yaml
!artifacts/*/epochs.csv
!artifacts/*/run.json
*.keras
*.h5
*.ckpt*
*.tflite
logs/

# Keep compact result files, ignore generated plots by default
results/*.png
results/*.pdf
